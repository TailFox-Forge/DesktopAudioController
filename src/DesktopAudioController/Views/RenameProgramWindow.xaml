<Window x:Class="DesktopAudioController.Views.RenameProgramWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="프로그램 이름 변경"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="현재 프로그램 이름을 사용자 지정 이름으로 덮어쓸 수 있습니다."
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="1"
                    Margin="0,12,0,0">
            <TextBlock FontWeight="SemiBold"
                       Text="현재 표시 이름" />
            <TextBlock x:Name="CurrentDisplayNameText"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="ExecutablePathText"
                       Margin="0,6,0,0"
                       FontSize="12"
                       Foreground="#666"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Margin="0,12,0,0">
            <TextBlock FontWeight="SemiBold"
                       Text="사용자 지정 이름" />
            <TextBox x:Name="CustomDisplayNameTextBox"
                     Margin="0,6,0,0"
                     MaxLength="80" />
            <TextBlock Margin="0,6,0,0"
                       FontSize="12"
                       Foreground="#666"
                       Text="비워 두면 자동으로 감지한 이름으로 되돌립니다." />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Margin="0,0,8,0"
                    Padding="10,4"
                    Click="ResetButton_OnClick"
                    Content="자동 이름 사용" />
            <Button Margin="0,0,8,0"
                    Padding="10,4"
                    Click="CancelButton_OnClick"
                    Content="취소" />
            <Button Padding="10,4"
                    Click="SaveButton_OnClick"
                    Content="저장" />
        </StackPanel>
    </Grid>
</Window>
