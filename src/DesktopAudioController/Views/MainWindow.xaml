<Window x:Class="DesktopAudioController.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DesktopAudioController"
        Width="560"
        Height="640"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="0,0,0,16">
            <TextBlock VerticalAlignment="Center"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Text="DesktopAudioController" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="88"
                        Margin="16,0,8,0"
                        Click="RefreshButton_OnClick"
                        Content="새로고침" />
                <Button Width="88"
                        Click="SettingsButton_OnClick"
                        Content="설정" />
            </StackPanel>
        </StackPanel>

        <Border Padding="12"
                CornerRadius="6"
                BorderBrush="#DDD"
                BorderThickness="1">
            <Grid>
                <TextBlock x:Name="EmptyStateText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#666"
                           Text="표시할 장치가 아직 선택되지 않았습니다. 설정에서 출력 장치를 고르세요."
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="DevicesItemsControl"
                                  ItemsSource="{Binding VisibleDevices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12"
                                        Padding="12"
                                        CornerRadius="6"
                                        BorderBrush="#DDD"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Name}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Foreground="#666"
                                                       Text="{Binding IsDefault, StringFormat=기본 장치: {0}}" />
                                        </DockPanel>
                                        <Slider Minimum="0"
                                                Maximum="100"
                                                Value="{Binding Volume}" />
                                        <DockPanel Margin="0,8,0,0">
                                            <TextBlock Text="{Binding Volume, StringFormat=마스터 볼륨: {0}%}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding IsMuted, StringFormat=음소거: {0}}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </DockPanel>
</Window>
