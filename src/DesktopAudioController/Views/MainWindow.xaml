<Window x:Class="DesktopAudioController.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DesktopAudioController"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Width="750"
        MinHeight="420"
        FontSize="13"
        SizeToContent="Height"
        WindowStartupLocation="Manual">
    <DockPanel Margin="16">
        <!-- 상단 헤더와 공통 액션 버튼 영역입니다. -->
        <Grid DockPanel.Dock="Top"
              Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Text="DesktopAudioController" />
                <TextBlock x:Name="VersionText"
                           Margin="0,4,0,0"
                           Foreground="#666"
                           Text="버전 확인 중..." />
                <TextBlock x:Name="UpdateStatusText"
                           Margin="0,4,0,0"
                           Foreground="#0A6"
                           MaxWidth="420"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />
                <TextBlock x:Name="StartupStatusText"
                           Margin="0,4,0,0"
                           Foreground="#B35A00"
                           MaxWidth="420"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top">
                <Button x:Name="UpdateButton"
                        Width="96"
                        Margin="0,0,8,0"
                        Click="UpdateButton_OnClick"
                        Content="다운로드"
                        ToolTip="새 zip을 내려받은 뒤 기존 실행 폴더에 덮어씁니다."
                        Visibility="Collapsed" />
                <Button Width="104"
                        Margin="0,0,8,0"
                        Click="OpenReleasePageButton_OnClick"
                        Content="릴리즈 노트"
                        ToolTip="GitHub 릴리즈 페이지를 엽니다." />
                <Button Width="88"
                        Margin="0,0,8,0"
                        Click="RefreshButton_OnClick"
                        Content="새로고침" />
                <Button Width="88"
                        Click="SettingsButton_OnClick"
                        Content="설정" />
            </StackPanel>
        </Grid>

        <!-- 본문 영역은 빈 상태 안내와 장치 카드 목록을 같은 영역에서 전환합니다. -->
        <Border Padding="12"
                CornerRadius="6"
                BorderBrush="#DDD"
                BorderThickness="1">
            <Grid>
                <!-- 아직 표시 장치를 고르지 않았을 때 보여주는 안내 문구입니다. -->
                <TextBlock x:Name="EmptyStateText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#666"
                           Text="메인 화면에 표시할 출력 장치가 없습니다. 상단 설정에서 장치를 고른 뒤 다시 돌아오세요."
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <!-- 사용자가 선택한 장치만 카드 형태로 렌더링합니다. -->
                    <ItemsControl x:Name="DevicesItemsControl"
                                  ItemsSource="{Binding VisibleDevices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- 장치 한 개의 마스터 볼륨 카드입니다. -->
                                <Border Margin="0,0,0,12"
                                        Padding="12"
                                        CornerRadius="6"
                                        BorderBrush="#DDD"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock FontSize="14"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Name}"
                                                       Text="{Binding Name}" />
                                            <StackPanel DockPanel.Dock="Right"
                                                        Orientation="Horizontal">
                                                <TextBlock Margin="0,0,8,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="#666"
                                                           Text="{Binding IsDefault, StringFormat=기본 장치: {0}}" />
                                                <Button Padding="8,2"
                                                        Click="SetDefaultButton_OnClick"
                                                        Content="기본 장치로 설정" />
                                            </StackPanel>
                                        </DockPanel>
                                        <!-- 장치 마스터 볼륨은 초기 화면에서 항상 바로 조절할 수 있게 둡니다. -->
                                        <Slider Minimum="0"
                                                Maximum="100"
                                                IsMoveToPointEnabled="True"
                                                Value="{Binding Volume}" />
                                        <DockPanel Margin="0,8,0,0">
                                            <TextBlock Text="{Binding Volume, StringFormat=마스터 볼륨: {0}%}" />
                                            <CheckBox DockPanel.Dock="Right"
                                                      Margin="16,0,0,0"
                                                      IsChecked="{Binding IsMuted}"
                                                      Content="음소거" />
                                        </DockPanel>

                                        <!-- 장치를 선택하면 프로그램별 세션 목록을 펼쳐 볼 수 있습니다. -->
                                                <ToggleButton Margin="0,12,0,0"
                                                              IsChecked="{Binding IsExpanded}"
                                                      Content="프로그램별 볼륨 열기" />

                                        <Border Margin="0,12,0,0"
                                                Padding="10"
                                                CornerRadius="6"
                                                BorderBrush="#EEE"
                                                BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExpanded}"
                                                                     Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,8"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Text="해당 장치에서 출력 중인 프로그램" />
                                                <ItemsControl ItemsSource="{Binding Sessions}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,0,0,8"
                                                                    Padding="8"
                                                                    CornerRadius="4"
                                                                    BorderBrush="#DDD"
                                                                    BorderThickness="1">
                                                                <StackPanel>
                                                                    <DockPanel Margin="0,0,0,6"
                                                                               LastChildFill="False">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Image Width="16"
                                                                                   Height="16"
                                                                                   Margin="0,0,6,0"
                                                                                   Source="{Binding IconImage}" />
                                                                            <StackPanel ToolTip="{Binding ExecutablePath}">
                                                                                <TextBlock VerticalAlignment="Center"
                                                                                           FontSize="13"
                                                                                           FontWeight="SemiBold"
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           Text="{Binding DisplayName}" />
                                                                                <TextBlock FontSize="11"
                                                                                           Foreground="#666"
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           ToolTip="{Binding ExecutablePath}"
                                                                                           Text="{Binding DisambiguationText}">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Visibility"
                                                                                                    Value="Visible" />
                                                                                            <Style.Triggers>
                                                                                                <Trigger Property="Text"
                                                                                                         Value="">
                                                                                                    <Setter Property="Visibility"
                                                                                                            Value="Collapsed" />
                                                                                                </Trigger>
                                                                                                <Trigger Property="Text"
                                                                                                         Value="{x:Null}">
                                                                                                    <Setter Property="Visibility"
                                                                                                            Value="Collapsed" />
                                                                                                </Trigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                        <StackPanel DockPanel.Dock="Right"
                                                                                    Margin="0,0,6,0"
                                                                                    Orientation="Horizontal"
                                                                                    VerticalAlignment="Center">
                                                                            <Button Margin="0,0,8,0"
                                                                                    Padding="8,2"
                                                                                    VerticalAlignment="Center"
                                                                                    Click="RenameSessionButton_OnClick"
                                                                                    Content="이름 변경" />
                                                                            <CheckBox Margin="8,0,0,0"
                                                                                      VerticalAlignment="Center"
                                                                                      VerticalContentAlignment="Center"
                                                                                      IsChecked="{Binding IsMuted}"
                                                                                      Content="음소거" />
                                                                        </StackPanel>
                                                                    </DockPanel>
                                                                    <Slider Minimum="0"
                                                                            Maximum="100"
                                                                            IsMoveToPointEnabled="True"
                                                                            Value="{Binding Volume}" />
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               Text="{Binding Volume, StringFormat=세션 볼륨: {0}%}" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </DockPanel>
</Window>
