<Window x:Class="DesktopAudioController.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="설정"
        Width="520"
        Height="640"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize">
    <DockPanel Margin="16">
        <!-- 하단 버튼 영역은 저장/취소만 담당합니다. -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Width="88"
                    Margin="0,0,8,0"
                    Click="CancelButton_OnClick"
                    Content="취소" />
            <Button Width="88"
                    Click="SaveButton_OnClick"
                    Content="저장" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 최초 실행 또는 설정 변경 시 표시할 장치를 선택하는 영역입니다. -->
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="표시할 출력 장치 선택" />
                <TextBlock Margin="0,8,0,16"
                           Foreground="#666"
                           Text="여기서 고른 장치만 메인 화면에 표시됩니다. 장치 목록은 실제 Windows Core Audio 기준으로 조회됩니다."
                           TextWrapping="Wrap" />

                <ItemsControl ItemsSource="{Binding AvailableDevices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- 장치별 체크 카드입니다. -->
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    CornerRadius="6"
                                    BorderBrush="#DDD"
                                    BorderThickness="1">
                                <DockPanel>
                                    <CheckBox VerticalAlignment="Center"
                                              IsChecked="{Binding IsSelected}">
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </CheckBox>
                                    <TextBlock DockPanel.Dock="Right"
                                               VerticalAlignment="Center"
                                               Foreground="#666"
                                               Text="{Binding IsConnected, StringFormat=연결됨: {0}}" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 장치 선택 아래에는 메인 화면 표시 방식 옵션을 둡니다. -->
                <Separator Margin="0,16,0,16" />

                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding ShowOnlyConnectedDevices}">
                    <TextBlock Text="연결된 장치만 표시" />
                </CheckBox>
                <TextBlock Margin="24,-4,0,12"
                           Foreground="#666"
                           Text="연결이 끊긴 장치나 오프라인 가상 장치는 메인 화면에서 숨깁니다."
                           TextWrapping="Wrap" />
                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding ShowSystemSounds}">
                    <TextBlock Text="시스템 사운드 세션도 표시" />
                </CheckBox>
                <TextBlock Margin="24,-4,0,12"
                           Foreground="#666"
                           Text="Windows 알림음과 시스템 소리도 프로그램 목록에 함께 표시합니다."
                           TextWrapping="Wrap" />

                <Separator Margin="0,8,0,16" />

                <TextBlock FontSize="15"
                           FontWeight="SemiBold"
                           Text="실행 동작" />
                <TextBlock Margin="0,8,0,16"
                           Foreground="#666"
                           Text="창을 닫을 때의 동작과 자동 실행 방식을 정합니다."
                           TextWrapping="Wrap" />

                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding MinimizeToTray}">
                    <TextBlock Text="닫기 버튼을 누르면 트레이로 최소화" />
                </CheckBox>
                <TextBlock Margin="24,-4,0,12"
                           Foreground="#666"
                           Text="완전히 종료하려면 트레이 메뉴의 종료를 사용합니다."
                           TextWrapping="Wrap" />
                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding RunAtWindowsStartup}">
                    <TextBlock Text="Windows 로그인 후 자동 실행" />
                </CheckBox>
                <TextBlock Margin="24,-4,0,12"
                           Foreground="#666"
                           Text="현재 사용자 계정에만 적용되며, 앱은 백그라운드에서 자동으로 시작됩니다."
                           TextWrapping="Wrap" />
                <CheckBox IsChecked="{Binding StartMinimized}"
                          IsEnabled="{Binding RunAtWindowsStartup}">
                    <TextBlock Text="자동 실행 시 시작하자마자 최소화" />
                </CheckBox>
                <TextBlock Margin="24,-4,0,0"
                           Foreground="#666"
                           Text="자동 실행이 켜져 있을 때만 적용됩니다."
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
