<Window x:Class="DesktopAudioController.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="설정"
        Width="520"
        Height="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Width="88"
                    Margin="0,0,8,0"
                    Click="CancelButton_OnClick"
                    Content="취소" />
            <Button Width="88"
                    Click="SaveButton_OnClick"
                    Content="저장" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Text="표시할 출력 장치 선택" />
                <TextBlock Margin="0,8,0,16"
                           Foreground="#666"
                           Text="처음에는 표시할 장치만 선택합니다. 실제 장치 조회는 Phase 2에서 Core Audio 연동으로 대체됩니다."
                           TextWrapping="Wrap" />

                <ItemsControl ItemsSource="{Binding AvailableDevices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    CornerRadius="6"
                                    BorderBrush="#DDD"
                                    BorderThickness="1">
                                <DockPanel>
                                    <CheckBox VerticalAlignment="Center"
                                              IsChecked="{Binding IsSelected}">
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </CheckBox>
                                    <TextBlock DockPanel.Dock="Right"
                                               VerticalAlignment="Center"
                                               Foreground="#666"
                                               Text="{Binding IsConnected, StringFormat=연결됨: {0}}" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,16,0,16" />

                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding ShowOnlyConnectedDevices}">
                    <TextBlock Text="연결된 장치만 메인 화면에 표시" />
                </CheckBox>
                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding MinimizeToTray}">
                    <TextBlock Text="닫기 대신 트레이로 최소화" />
                </CheckBox>
                <CheckBox IsChecked="{Binding StartMinimized}">
                    <TextBlock Text="시작 시 최소화" />
                </CheckBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
