<Window x:Class="DesktopAudioController.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="설정"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Width="750"
        Height="720"
        MinHeight="420"
        FontSize="13"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <!-- 하단 버튼 영역에는 로그 폴더 바로가기와 저장/취소를 함께 둡니다. -->
        <Grid DockPanel.Dock="Bottom"
              Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Width="120"
                    HorizontalAlignment="Left"
                    Click="OpenLogFolderButton_OnClick"
                    Content="로그 폴더 열기" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="88"
                        Margin="0,0,8,0"
                        Click="CancelButton_OnClick"
                        Content="취소" />
                <Button Width="88"
                        Click="SaveButton_OnClick"
                        Content="저장" />
            </StackPanel>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 최초 실행 또는 설정 변경 시 표시할 장치를 선택하는 영역입니다. -->
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="표시할 출력 장치 선택" />
                <TextBlock Margin="0,8,0,16"
                           Foreground="#666"
                           Text="여기서 고른 장치만 메인 화면에 표시됩니다. 장치 목록은 실제 Windows Core Audio 기준으로 조회됩니다."
                           TextWrapping="Wrap" />

                <ItemsControl ItemsSource="{Binding AvailableDevices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- 장치별 체크 카드입니다. -->
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    CornerRadius="6"
                                    BorderBrush="#DDD"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsSelected}">
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </CheckBox>
                                    <TextBlock Grid.Column="1"
                                               Margin="12,0,0,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="#666"
                                               Text="{Binding IsConnected, StringFormat=연결됨: {0}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 장치 선택 아래에는 메인 화면 표시 방식 옵션을 둡니다. -->
                <Separator Margin="0,16,0,16" />

                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding ShowOnlyConnectedDevices}">
                    <TextBlock Text="연결된 장치만 표시" />
                </CheckBox>
                <TextBlock Margin="24,-4,0,12"
                           Foreground="#666"
                           Text="연결이 끊긴 장치나 오프라인 가상 장치는 메인 화면에서 숨깁니다."
                           TextWrapping="Wrap" />
                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding ShowSystemSounds}">
                    <TextBlock Text="시스템 사운드 세션도 표시" />
                </CheckBox>
                <TextBlock Margin="24,-4,0,12"
                           Foreground="#666"
                           Text="Windows 알림음과 시스템 소리도 프로그램 목록에 함께 표시합니다."
                           TextWrapping="Wrap" />
                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding ShowOnlyActiveSessions}">
                    <TextBlock Text="재생 중인 앱만 보기" />
                </CheckBox>
                <TextBlock Margin="24,-4,0,12"
                           Foreground="#666"
                           Text="체크하지 않으면 현재 조용한 앱도 목록에 유지하고, 상태 문구로만 구분합니다."
                           TextWrapping="Wrap" />

                <Separator Margin="0,8,0,16" />

                <TextBlock FontSize="15"
                           FontWeight="SemiBold"
                           Text="업데이트 확인" />
                <TextBlock Margin="0,8,0,16"
                           Foreground="#666"
                           Text="기본값은 정식(stable) 릴리즈만 확인합니다. 필요하면 프리릴리즈도 함께 안내할 수 있습니다."
                           TextWrapping="Wrap" />

                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding IncludePreReleaseUpdates}">
                    <TextBlock Text="프리릴리즈 업데이트도 함께 확인" />
                </CheckBox>
                <TextBlock Margin="24,-4,0,12"
                           Foreground="#666"
                           Text="체크하면 테스트용 미리보기 버전까지 새 버전 안내에 포함합니다."
                           TextWrapping="Wrap" />

                <Separator Margin="0,8,0,16" />

                <TextBlock FontSize="15"
                           FontWeight="SemiBold"
                           Text="실행 동작" />
                <TextBlock Margin="0,8,0,16"
                           Foreground="#666"
                           Text="창을 닫을 때의 동작과 자동 실행 방식을 정합니다."
                           TextWrapping="Wrap" />

                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding MinimizeToTray}">
                    <TextBlock Text="닫기 버튼을 누르면 트레이로 최소화" />
                </CheckBox>
                <TextBlock Margin="24,-4,0,12"
                           Foreground="#666"
                           Text="완전히 종료하려면 트레이 메뉴의 종료를 사용합니다."
                           TextWrapping="Wrap" />
                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding RunAtWindowsStartup}">
                    <TextBlock Text="Windows 로그인 후 자동 실행" />
                </CheckBox>
                <TextBlock Margin="24,-4,0,12"
                           Foreground="#666"
                           Text="현재 사용자 계정에만 적용되며, 앱은 백그라운드에서 자동으로 시작됩니다."
                           TextWrapping="Wrap" />
                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding StartMinimized}"
                          IsEnabled="{Binding RunAtWindowsStartup}">
                    <TextBlock Text="자동 실행 시 시작하자마자 최소화" />
                </CheckBox>
                <TextBlock Margin="24,-4,0,12"
                           Foreground="#666"
                           Text="자동 실행이 켜져 있을 때만 적용됩니다."
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
